* ---------------------------------------------------------
* 2. 绘制日内 48 个时段的期望福利变动贡献分布图 (极速瘦身版)
* ---------------------------------------------------------
preserve
display "   -> Plotting Welfare Decomposition across 24 hours..."

* 【🚨 核心降维修复】：只保留画图需要的两个变量，瞬间释放几十GB的运算空间！
keep alt_index Delta_CS
drop if missing(Delta_CS)

* 计算每个时段在全体样本中的平均期望福利变动
collapse (mean) mean_delta_cs = Delta_CS, by(alt_index)

#delimit ;
quietly twoway 
    /* 将正负福利变动用不同颜色区分：正福利（赚了）用绿色，负福利（亏了）用红色 */
    (bar mean_delta_cs alt_index if mean_delta_cs >= 0, fcolor(green%70) lcolor(green%70) lwidth(none))
    (bar mean_delta_cs alt_index if mean_delta_cs < 0, fcolor(red%70) lcolor(red%70) lwidth(none))
